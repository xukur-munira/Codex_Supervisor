{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "dist/**/*.d.ts",
    "scripts/**/*.js",
    "test/**/*.js"
  ],
  "exclude": ["node_modules"]
}
