{
  "name": "codex-supervisor",
  "version": "1.0.7",
  "description": "External Supervisor for OpenAI Codex CLI - manages projects with task decomposition, worker spawning, checkpoint review, and completion verification",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codex-supervisor": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-static.js",
    "watch": "tsc --watch",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config test/jest.config.js",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve"
  },
  "keywords": [
    "openai",
    "codex",
    "codex-cli",
    "supervisor",
    "task-management",
    "agent-orchestration"
  ],
  "files": [
    "dist",
    "README.md",
    "mcp-config.example.json",
    "mcp-config.example.toml",
    "install.bat",
    "install.sh"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "ioredis": "^5.6.0",
    "uuid": "^11.0.0",
    "watcher": "^2.3.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
